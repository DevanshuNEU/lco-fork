# Resend API key - create at resend.com/api-keys
RESEND_API_KEY=re_...

# Resend Audience ID - create at resend.com/audiences
RESEND_AUDIENCE_ID=...

# Chrome Web Store listing URL - set this in Vercel once the extension is published
NEXT_PUBLIC_CWS_URL=https://chromewebstore.google.com/detail/saar-local-context-optimi/YOUR_EXTENSION_ID
